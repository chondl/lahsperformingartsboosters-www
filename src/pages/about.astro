---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
const page = await getEntry('pages', 'about');
if (!page) throw new Error('Missing content: pages/about');
const { Content } = await render(page);
---
<BaseLayout title="About & Contact" description="About the LAHS Performing Arts Boosters.">
  <article class="container section prose"><h1>{page.data.title}</h1><Content /></article>
</BaseLayout>
